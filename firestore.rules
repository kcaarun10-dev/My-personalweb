rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow admins to do anything (Requires specific Google Auth Login)
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'kcaarun10@gmail.com';
    }

    // 1. Posts Collection (Admin read/write, Public read)
    match /posts/{postId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // 2. Comments Collection (Public read, Public create, Admin edit/delete)
    match /comments/{commentId} {
      allow read: if true;
      allow create: if true; // Allows anonymous visitors to leave comments
      allow update, delete: if isAdmin(); // Only admins can moderate comments
    }

    // 3. Likes Collection (Public read, Public update via increment)
    match /likes/{postId} {
      allow read: if true;
      
      // Allow first like creation (must exactly set count to 1)
      allow create: if true 
                    && request.resource.data.keys().hasOnly(['count']) 
                    && request.resource.data.count == 1;

      // Allow future likes to increment the counter by exactly 1
      allow update: if true 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count'])
                    && request.resource.data.count == resource.data.count + 1;
                    
      allow delete: if isAdmin();
    }
  }
}
